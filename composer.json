{
  "name": "mehul/quark",
  "description": "AI assistant plugin for WordPress",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": "^8.2",
    "league/oauth2-server": "^9.3",
    "nyholm/psr7": "^1.8",
    "phpseclib/phpseclib": "^3.0"
  },
  "require-dev": {
    "phpcompatibility/php-compatibility": "^9.3",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/phpstan": "^1.11",
    "php-stubs/wordpress-stubs": "^6.6",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "Quark\\": "src/"
    }
  },
  "scripts": {
    "lint:php": "find . -name '*.php' -not -path './vendor/*' -print0 | xargs -0 -n1 php -l",
    "lint:wpcs": "phpcs --standard=phpcs.xml.dist",
    "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
    "test": [
      "@lint:php",
      "@lint:wpcs",
      "@analyse"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.2.0"
    }
  }
}
