parameters:
  level: 6
  paths:
    - src
    - aculect-ai-companion.php
  parallel:
    maximumNumberOfProcesses: 1
  bootstrapFiles:
    - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    - phpstan-bootstrap.php
    - vendor/autoload.php
  ignoreErrors:
    -
      identifier: missingType.iterableValue
